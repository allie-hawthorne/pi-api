    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "16.5.0",
    "express": "^4.17.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "9.0.2",
    "jwt-decode": "4.0.0",
    "mysql2": "3.14.0",
    "reflect-metadata": "0.2.2",
    "typeorm": "0.3.22",
    "zod": "^4.4.3"
  },
