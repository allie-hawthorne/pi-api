{
  "name": "pi-api",
  "version": "1.0.0",
  "description": "Express.js backend to be hosted on my Raspberry Pi, supporting my projects",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "concurrently \"tsc --watch\" \"nodemon dist/index.js\"",
    "start": "node dist/index.js",
    "update": "git pull && pnpm install && pnpm run build && sudo reboot"
  },
